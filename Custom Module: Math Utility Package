def is_prime(n):
    for i in range(2, n):
        if n % i == 0:
            return False
    return True

def fibonacci(n):
    a, b = 0, 1
    for _ in range(n):
        print(a, end=" ")
        a, b = b, a + b

def factorial(n):
    fact = 1
    for i in range(1, n + 1):
        fact *= i
    return fact
